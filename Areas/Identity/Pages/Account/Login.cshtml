@page
@model LoginModel
@{
    ViewData["Title"] = "Login";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-5">

            <div class="card shadow-lg border-0 rounded-4">
                <div class="card-body p-4">

                    <h2 class="text-center fw-bold mb-2 text-primary">
                        Welcome!
                    </h2>

                    <p class="text-center text-muted mb-4">
                        Login to continue
                    </p>

                    <form method="post">

                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <!-- EMAIL -->
                        <div class="form-floating mb-3">
                            <input asp-for="Input.Email" class="form-control" placeholder="name@example.com" />
                            <label>Email address</label>
                            <span asp-validation-for="Input.Email" class="text-danger small"></span>
                        </div>

                        <!-- PASSWORD -->
                        <div class="form-floating mb-3">
                            <input asp-for="Input.Password" class="form-control" placeholder="password" />
                            <label>Password</label>
                            <span asp-validation-for="Input.Password" class="text-danger small"></span>
                        </div>

                        <!-- REMEMBER + FORGOT -->
                        <div class="d-flex justify-content-between align-items-center mb-3">
                            <div class="form-check">
                                <input asp-for="Input.RememberMe" class="form-check-input" />
                                <label class="form-check-label">Remember me</label>
                            </div>

                            <a asp-page="./ForgotPassword" class="small text-decoration-none text-primary">
                                Forgot Password?
                            </a>
                        </div>

                        <!-- LOGIN BUTTON -->
                        <button type="submit" class="w-100 btn btn-primary btn-lg rounded-3">
                            Login 
                        </button>

                        <!-- REGISTER -->
                        <div class="text-center mt-3">
                            <a asp-page="./Register" class="text-decoration-none">
                                Don’t have an account? Register
                            </a>
                        </div>

                    </form>

                </div>
            </div>

        </div>
    </div>

</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}

