@{
    ViewData["Title"] = "Privacy Policy";
}

<div class="container mt-5">
    <div class="privacy-card shadow-lg rounded-4 p-5">
        <h1 class="fw-bold text-primary mb-4">Privacy Policy</h1>
        <p class="lead text-muted mb-4">
            Your privacy is important to us. This policy explains how CampusEventsApp collects, uses, and protects your information.
        </p>

        <h3 class="fw-semibold text-secondary mt-4">1. Information We Collect</h3>
        <p>
            We collect personal details such as your name, email address, and event registrations to provide you with a seamless experience.
        </p>

        <h3 class="fw-semibold text-secondary mt-4">2. How We Use Your Information</h3>
        <ul>
            <li>To manage your event registrations</li>
            <li>To personalize your dashboard and notifications</li>
            <li>To improve our services and user experience</li>
        </ul>

        <h3 class="fw-semibold text-secondary mt-4">3. Data Protection</h3>
        <p>
            We implement industry-standard security measures to protect your data against unauthorized access, alteration, or disclosure.
        </p>

        <h3 class="fw-semibold text-secondary mt-4">4. Sharing of Information</h3>
        <p>
            We do not sell or share your personal information with third parties, except as required by law.
        </p>

        <h3 class="fw-semibold text-secondary mt-4">5. Your Rights</h3>
        <p>
            You have the right to access, update, or delete your personal information. Contact us if you wish to exercise these rights.
        </p>

        <h3 class="fw-semibold text-secondary mt-4">6. Updates to This Policy</h3>
        <p>
            We may update this Privacy Policy from time to time. Any changes will be posted on this page with the updated date.
        </p>

        <div class="mt-5 text-center">
            <a asp-controller="Home" asp-action="Index" class="btn btn-primary btn-lg rounded-pill">
                Back to Home
            </a>
        </div>
    </div>
</div>

