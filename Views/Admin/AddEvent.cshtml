@model CampusEventsApp.Models.Event
@{
    ViewData["Title"] = "Add New Event";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h4 class="mb-0">➕ Create New Campus Event</h4>
                </div>
                <div class="card-body">

                  
                    <form asp-controller="Admin" asp-action="AddEvent" method="post">
                        @Html.AntiForgeryToken()

                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="row">
                            <div class="col-md-8 mb-3">
                                <label asp-for="Title" class="form-label fw-bold">Event Name</label>
                                <input asp-for="Title" class="form-control" placeholder="e.g., Spring Tech Symposium" />
                                <span asp-validation-for="Title" class="text-danger"></span>
                            </div>

                            <div class="col-md-4 mb-3">
                                <label asp-for="Category" class="form-label fw-bold">Category</label>
                                <select asp-for="Category" class="form-select">
                                    <option value="">Select...</option>
                                    <option value="Workshop">Workshop</option>
                                    <option value="Seminar">Seminar</option>
                                    <option value="Social">Social</option>
                                    <option value="Sports">Sports</option>
                                </select>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-6 mb-3">
                                <label asp-for="EventDate" class="form-label fw-bold">Date</label>
                                <input asp-for="EventDate" type="date" class="form-control" />
                                <span asp-validation-for="EventDate" class="text-danger"></span>
                            </div>

                            <div class="col-md-6 mb-3">
                                <label asp-for="EventTime" class="form-label fw-bold">Time</label>
                                <input asp-for="EventTime" type="time" class="form-control" />
                                <span asp-validation-for="EventTime" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="row">
                            <div class="col-md-8 mb-3">
                                <label asp-for="Venue" class="form-label fw-bold">Venue / Location</label>
                                <input asp-for="Venue" class="form-control" placeholder="e.g., Main Auditorium" />
                                <span asp-validation-for="Venue" class="text-danger"></span>
                            </div>

                            <div class="col-md-4 mb-3">
                                <label asp-for="TotalCapacity" class="form-label fw-bold">Capacity</label>
                                <input asp-for="TotalCapacity" type="number" class="form-control" min="1" />
                                <span asp-validation-for="TotalCapacity" class="text-danger"></span>
                            </div>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Description" class="form-label fw-bold">Event Description</label>
                            <textarea asp-for="Description" class="form-control" rows="4"
                                      placeholder="Detailed information about the event..."></textarea>
                            <span asp-validation-for="Description" class="text-danger"></span>
                        </div>

                        <div class="d-flex justify-content-between">
                            <a asp-controller="Admin" asp-action="ManageEvents"
                               class="btn btn-outline-secondary">
                                Cancel
                            </a>

                            <button type="submit" class="btn btn-success px-4">
                                Create Event
                            </button>
                        </div>
                    </form>

                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}