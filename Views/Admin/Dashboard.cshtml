@{
    ViewData["Title"] = "Admin Dashboard";
}

<div class="container mt-4">
    <div class="p-5 mb-4 bg-light rounded-3 border border-primary border-2">
        <div class="container-fluid py-2">
            <h1 class="display-5 fw-bold text-primary">Admin Control Panel</h1>
            <p class="col-md-8 fs-4">
                Manage campus events, oversee student registrations, and administer the system.
            </p>
        </div>
    </div>

    <div class="row g-4 text-center">

        <!-- Total Events -->
        <div class="col-md-6">
            <div class="card shadow-sm border-info h-100">
                <div class="card-body py-4">
                    <h2 class="display-4 fw-bold text-info">
                        @(ViewBag.TotalEvents ?? 0)
                    </h2>
                    <p class="text-muted mb-0">Total Events</p>
                </div>
            </div>
        </div>

        <!-- Total Registrations -->
        <div class="col-md-6">
            <div class="card shadow-sm border-success h-100">
                <div class="card-body py-4">
                    <h2 class="display-4 fw-bold text-success">
                        @(ViewBag.TotalRegistrations ?? 0)
                    </h2>
                    <p class="text-muted mb-0">Total Registrations</p>
                </div>
            </div>
        </div>

    </div>

    <div class="mt-5 p-4 bg-white rounded shadow-sm border">
        <h3 class="mb-4">Quick Actions</h3>

        <div class="d-flex gap-3 flex-wrap">

            <a asp-controller="Admin" asp-action="AddEvent"
               class="btn btn-primary btn-lg px-4 shadow-sm">
                ➕ Create New Event
            </a>

            <a asp-controller="Admin" asp-action="ManageEvents"
               class="btn btn-outline-dark btn-lg px-4 shadow-sm">
                📅 Manage Events
            </a>

            <a asp-controller="Admin" asp-action="Users" class="btn btn-outline-secondary btn-lg px-4 shadow-sm">
                👥 View Users
            </a>

        </div>
    </div>
</div>
<footer class="footer">
    <div class="container">
        &copy; 2026 - CampusEventsApp -
        <a asp-area="" asp-controller="Home" asp-action="Privacy" class="text-white text-decoration-none">
            Privacy
        </a>
    </div>
</footer>  