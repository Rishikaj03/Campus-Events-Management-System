@model IEnumerable<CampusEventsApp.Models.Event>

@{
    ViewData["Title"] = "Manage Events";
}

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>🛠️ Manage Events</h2>
        <a asp-action="AddEvent" class="btn btn-primary">➕ Add New Event</a>
    </div>

    <div class="card shadow-sm">
        <div class="card-body p-0">
            <table class="table table-hover table-striped mb-0">
                <thead class="table-dark">
                    <tr>
                        <th>Event Name</th>
                        <th>Date & Time</th>
                        <th>Venue</th>
                        <th>Status</th>
                        <th class="text-center">Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @if (!Model.Any())
                    {
                        <tr>
                            <td colspan="5" class="text-center py-4 text-muted">No events found.</td>
                        </tr>
                    }
                    else
                    {
                        @foreach (var item in Model)
                        {
                            <tr>
                                <td class="fw-bold">@item.Title</td>
                                <td>@item.EventDate.ToShortDateString() at @item.EventTime.ToString(@"hh\:mm")</td>
                                <td>@item.Venue</td>
                                <td>
                                    @if (item.IsOpen)
                                    {
                                        <span class="badge bg-success">Open</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-danger">Closed</span>
                                    }
                                </td>
                                <td class="text-center">
                                    <div class="d-flex gap-1 justify-content-center">

                                        <!-- PARTICIPANTS -->
                                        <a asp-action="Participants" asp-route-id="@item.Id" class="btn btn-sm btn-info text-white">
                                            👥
                                        </a>

                                        <!-- TOGGLE -->
                                        <form asp-action="ToggleStatus" asp-route-id="@item.Id" method="post">
                                            <button type="submit" class="btn btn-sm @(item.IsOpen ? "btn-warning" : "btn-success")">
                                                @(item.IsOpen ? "Close" : "Open")
                                            </button>
                                        </form>

                                        <!-- EDIT -->
                                        <a asp-action="EditEvent" asp-route-id="@item.Id" class="btn btn-sm btn-secondary">
                                            ✏️
                                        </a>

                                        <!-- DELETE -->
                                        <form asp-action="DeleteEvent" asp-route-id="@item.Id" method="post"
                                              onsubmit="return confirm('Delete this event?');">
                                            @Html.AntiForgeryToken()
                                            <button type="submit" class="btn btn-sm btn-danger">🗑️</button>
                                        </form>

                                    </div>
                                </td>
                            </tr>
                        }
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>